{
    "cluster": "test",
    "namespace": "srtl-development",
    "config": "review",
    "deploy_azure_backing_services": false,
    "enable_postgres_ssl": false,
    "startup_command":
    [
        "/bin/sh",
        "-c",
        "bin/rails server -b 0.0.0.0"
    ],
    "worker_command":
    [
        "/bin/sh",
        "-c",
        "bin/rake db:setup_or_migrate && bin/bundle exec bin/jobs"
    ],
    "enable_logit": true,
    "dataset_name": "claim_events_test",
    "enable_dfe_analytics_federated_auth": true,
    "blob_delete_after_days": 60,
    "blob_delete_retention_days": null,
    "container_delete_retention_days": null
}