<% content_for(:page_title, page_title("Uploaded employment proof", journey: current_journey_routing_name)) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-l">Uploaded employment proof</h1>

    <h2 class="govuk-heading-m">Files added</h2>

    <table class="govuk-table">
      <tbody class="govuk-table__body">
        <% @form.uploaded_blobs.each_with_index do |blob, index| %>
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">File <%= index + 1 %></td>
            <td class="govuk-table__cell">
              <%= link_to blob.filename.to_s, rails_storage_proxy_path(blob), target: "_blank", rel: "noopener noreferrer", class: "govuk-link" %>, <%= number_to_human_size(blob.byte_size) %>
            </td>
            <td class="govuk-table__cell">
              <%= link_to "Delete", claim_path(current_journey_routing_name, "delete-employment-proof", blob_id: blob.id), class: "govuk-link govuk-link--no-visited-state" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%= form_with model: @form, url: @form.url, method: :patch, builder: GOVUKDesignSystemFormBuilder::FormBuilder, html: { novalidate: false } do |f| %>
      <%= f.govuk_error_summary %>
      <%= f.govuk_collection_radio_buttons :upload_another, [
            OpenStruct.new(id: "yes", name: "Yes"),
            OpenStruct.new(id: "no", name: "No")
          ], :id, :name,
          legend: { text: "Do you want to upload another document?", tag: "h2", size: "m" } %>
      <%= f.govuk_submit "Continue" %>
    <% end %>
  </div>
</div>
