<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= form_with model: @form, url: @form.url, builder: GOVUKDesignSystemFormBuilder::FormBuilder do |f| %>
      <%= f.govuk_error_summary %>

      <%= f.govuk_collection_radio_buttons :teaching_qualification_confirmation,
        @form.radio_options,
        :id,
        :name,
        legend: {
          text: "Do you hold one of these teaching qualifications?",
          tag: "h1",
          size: "xl"
        },
        hint: -> do %>
          <p class="govuk-body">
            You must hold one of the following to be eligible:
          </p>

          <%= govuk_list [
            "qualified teacher status (QTS)",
            "early years teacher status (EYTS)",
            "early years professional status (EYPS)",
          ], type: :bullet %>

          <p class="govuk-body">
            If you’re not sure check your certificates.
          </p>
      <% end %>

      <%= f.govuk_submit %>
    <% end %>
  </div>
</div>
