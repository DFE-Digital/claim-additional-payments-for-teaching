<% content_for(:page_title, page_title("Check your document", journey: current_journey_routing_name, show_error: @form.errors.any?)) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= form_with model: @form, url: @form.url, method: :patch, builder: GOVUKDesignSystemFormBuilder::FormBuilder, html: { novalidate: false } do |f| %>
      <%= f.govuk_error_summary %>
      <h1 class="govuk-heading-l">Check your document</h1>

      <%= f.hidden_field :blob_id, value: @form.latest_blob&.id %>

      <% if @form.latest_blob %>
        <p class="govuk-body">
          <%= link_to @form.latest_blob.filename.to_s, rails_storage_proxy_path(@form.latest_blob), target: "_blank", rel: "noopener noreferrer", class: "govuk-link" %>
        </p>
      <% end %>

      <%= f.govuk_collection_radio_buttons :confirmed,
          @form.radio_options,
          :id, :name,
          legend: { text: "Is this file correct?", tag: "h2", size: "m" },
          hint: { text: @form.latest_blob&.filename } %>

      <%= f.govuk_submit "Continue" %>
    <% end %>
  </div>
</div>
