<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-xl">You are eligible to apply</h1>

    <p class="govuk-body">
      You can apply because the nursery you work in is eligible and you have the right qualification.
    </p>

    <h2 class="govuk-heading-m">What you need to do next</h2>

    <p class="govuk-body">
      To continue your claim, you need to prove your identity using GOV.UK One Login.
    </p>

    <%= form_with model: @form, url: @form.url, builder: GOVUKDesignSystemFormBuilder::FormBuilder do |f| %>
      <%= f.govuk_submit %>
    <% end %>
  </div>
</div>
