<h1 class="govuk-heading-l">
  Manage users
</h1>

<%= govuk_table do |table| %>
  <% table.with_head do |head| %>
    <% head.with_row do |row| %>
      <% row.with_cell(text: "Name") %>
      <% row.with_cell(text: "Email address") %>
      <% row.with_cell(text: "Roles") %>
      <% row.with_cell(text: "Deleted at") %>
    <% end %>
  <% end %>

  <% table.with_body do |body| %>
    <% @users.each do |user| %>
      <% body.with_row do |row| %>
        <% row.with_cell(header: true, text: (govuk_link_to (user.full_name.presence || "Unknown"), admin_user_path(user))) %>
        <% row.with_cell(text: user.email) %>
        <% row.with_cell(text: user.roles.count) %>
        <% row.with_cell(text: user.deleted_at) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
