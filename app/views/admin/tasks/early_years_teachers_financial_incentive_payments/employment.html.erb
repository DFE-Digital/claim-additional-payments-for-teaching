<% content_for(:page_title) {
  page_title(
    "Claim #{@claim.reference} employment check for #{@claim.policy.short_name}"
  )
} %>

<% content_for :back_link do %>
  <%= govuk_back_link href: admin_claim_tasks_path(@claim) %>
<% end %>

<%= form_with(
  model: @form,
  scope: :form,
  url: root_path,
  builder: GOVUKDesignSystemFormBuilder::FormBuilder
) do |f| %>
  <%= f.govuk_error_summary %>
<% end %>

<div class="govuk-grid-row">
  <%= render claim_summary_view, claim: @claim, heading: "Employment" %>

  <div class="govuk-grid-column-two-thirds">
    <h2 class="govuk-heading-l">Employment</h2>

    <p class="govuk-body">
      Employment evidence uploaded by claimant on
      <%= @claim.submitted_at.strftime("%-d/%-m/%Y") %>
    </p>

    <% provider = @claim.eligibility.eligible_eytfi_provider %>

    <h3 class="govuk-heading-m">Selected nursery</h3>

    <%= govuk_summary_list do |summary_list| %>
      <% summary_list.with_row do |row| %>
        <% row.with_key { "Provider URN" } %>
        <% row.with_value { provider.urn } %>
      <% end %>

      <% summary_list.with_row do |row| %>
        <% row.with_key { "Provider name" } %>
        <% row.with_value { provider.name } %>
      <% end %>

      <% summary_list.with_row do |row| %>
        <% row.with_key { "Provider address line 1" } %>
        <% row.with_value { provider.address_line_1 } %>
      <% end %>

      <% summary_list.with_row do |row| %>
        <% row.with_key { "Provider address line 2" } %>
        <% row.with_value { provider.address_line_2 } %>
      <% end %>

      <% summary_list.with_row do |row| %>
        <% row.with_key { "Provider address line 3" } %>
        <% row.with_value { provider.address_line_3 } %>
      <% end %>

      <% summary_list.with_row do |row| %>
        <% row.with_key { "Provider town" } %>
        <% row.with_value { provider.town } %>
      <% end %>

      <% summary_list.with_row do |row| %>
        <% row.with_key { "Postcode" } %>
        <% row.with_value { provider.postcode } %>
      <% end %>
    <% end %>

    <h3 class="govuk-heading-m">Uploaded evidence</h3>

    <ul class="govuk-list">
      <% @claim.eligibility.employment_proofs.each do |proof| %>
        <li>
          <% if proof.blob.malware_scan_passed? %>
            <%= link_to(
              proof.filename.to_s,
              rails_blob_url(proof),
              class: "govuk-link",
              target: "_blank",
              rel: "noopener"
            ) %>
          <% elsif proof.blob.malware_scan_failed? %>
            <%= "#{proof.filename} (malware scan failed)" %>
          <% else %>
            <%= "#{proof.filename} (malware scan pending)" %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="govuk-grid-column-two-thirds">
    <% if @form.task.persisted? %>
      <%= render "task_outcome", task: @form.task, notes: @notes %>
    <% else %>
      <%= render "form", task_name: "employment", claim: @claim %>
    <% end %>

    <%= render "task_notes_section" %>

    <%= render(
      partial: "admin/task_pagination",
      locals: { task_pagination: @task_pagination }
    ) %>
  </div>
</div>
