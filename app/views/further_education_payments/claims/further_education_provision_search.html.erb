<% content_for(:page_title, page_title(@form.t(:question), journey: current_journey_routing_name, show_error: @form.errors.any?)) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <%= form_with model: @form,
      url: @form.url,
      method: :patch,
      builder: GOVUKDesignSystemFormBuilder::FormBuilder,
      html: { novalidate: false } do |f| %>
      <%= f.govuk_error_summary %>

      <%= f.govuk_school_search(
        :provision_search,
        search_path: school_search_index_path(fe_only: true),
        result_attribute: :possible_school_id,
        label: {
          text: @form.t(:question),
          size: "l"
        },
        hint: {
          text: "Enter the name or postcode using at least 3 characters."
        }
      ) %>

      <p class="govuk-body">
        You can find 
        <%= govuk_link_to("a list of eligible further education providers and payment values (opens in a new tab).",
          "https://www.gov.uk/guidance/targeted-retention-incentive-payments-for-fe-teachers#Eligible-FE-providers", target: "_blank")
        %>
      </p>

      <%= f.govuk_submit %>
    <% end %>
  </div>
</div>
