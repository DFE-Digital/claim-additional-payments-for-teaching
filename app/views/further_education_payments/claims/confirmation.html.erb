<% content_for(:page_title, page_title("Claim submitted", journey: current_journey_routing_name)) %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    <div class="govuk-panel govuk-panel--confirmation">
      <h1 class="govuk-panel__title" id="submitted-title">
        You applied for a further education targeted retention incentive payment
      </h1>

      <div class="govuk-panel__body">
        Your reference number<br>
        <strong><%= @form.reference %></strong>
      </div>
    </div>

    <p class="govuk-body">
      We have sent you a confirmation email to <%= @form.email_address %>.
    </p>

    <h2 class="govuk-heading-m">
      Updates on any future targeted retention incentive payments
    </h2>

    <p class="govuk-body">
    As long as you continue to meet any eligibility criteria, there may be opportunities to claim a targeted retention incentive in the future.
    </p>

    <p class="govuk-body">
      You can set a reminder so you know when you are able to apply. We cannot issue payments unless you apply.
    </p>

    <%= govuk_button_link_to "Set reminder", reminder_path(journey: journey.routing_name, slug: "personal-details") %>
  </div>
</div>
