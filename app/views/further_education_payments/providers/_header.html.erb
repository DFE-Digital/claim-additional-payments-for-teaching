<% header_html = govuk_header do |header| %>
  <% header.with_service_navigation(
    navigation_items: provider_nav_items,
    current_path: request.fullpath
  ) %>

  <% header.with_phase_banner(tag: { text: "Beta" }, classes: "govuk-width-container") do %>
    <%= render "shared/phase_banner" %>
  <% end %>
<% end %>

<%
  header_document = Nokogiri::HTML.fragment(header_html)
  sign_out_link = header_document.css('a[href="/further-education-payments/providers/session"]').first
  sign_out_link["data-method"] = "delete" if sign_out_link
%>

<%= header_document.to_s.html_safe %>
